@page "/"
@inherits LocalizedComponentBase

<PageTitle>Denisa & Ivo · 26. 9. 2026</PageTitle>

@* ---------- HERO ---------- *@
<header class="hero">
    <svg class="leaf-decor leaf-tl" viewBox="0 0 200 200" aria-hidden="true">@_branch</svg>
    <svg class="leaf-decor leaf-br" viewBox="0 0 200 200" aria-hidden="true">@_branch</svg>

    <div class="hero-inner">
        <h1 class="hero-names">@C.CoupleNames</h1>
        <p class="hero-surnames">Oravcová &nbsp;&amp;&nbsp; Točený</p>

        <svg class="sprig" viewBox="0 0 200 22" aria-hidden="true">@_sprig</svg>

        <p class="hero-poem">@C.Poem</p>

        <div class="hero-date">
            <span class="hero-month">@C.Month</span>
            <div class="hero-date-row">
                <span class="hero-weekday">@C.Weekday</span>
                <span class="hero-day">26</span>
                <span class="hero-time">13:00</span>
            </div>
            <span class="hero-year">2026</span>
            <span class="hero-place">Lysovický rybník</span>
        </div>

        <a class="btn btn-primary btn-lg" href="@SiteConfig.GoogleFormUrl" target="_blank" rel="noopener">
            @C.RsvpButton
        </a>

        <a class="hero-menu-link" href="menu">@C.MenuNavLabel <span aria-hidden="true">→</span></a>
    </div>
</header>

@* ---------- AKTUALITY ---------- *@
<NewsSection />

@* ---------- POZVANIE ---------- *@
<section class="section section-invite">
    <div class="container narrow center">
        <h2 class="script-heading">@C.InviteHeading</h2>
        @foreach (var paragraph in C.InviteParagraphs)
        {
            <p class="lead">@paragraph</p>
        }
        <figure class="invitation">
            <img src="motiv.jpg" alt="Svadobná pozvánka — Denisa & Ivo" loading="lazy" />
        </figure>
    </div>
</section>

@* ---------- INFORMÁCIE ---------- *@
<section class="section section-info">
    <div class="container">
        <h2 class="section-title">@C.InfoHeading</h2>
        <div class="info-grid">
            @foreach (var card in C.InfoCards)
            {
                <InfoCard Item="card" />
            }
            <div class="info-card info-card-palette">
                <h3>@C.PaletteTitle</h3>
                <p>@C.PaletteText</p>
                <ColorPalette />
            </div>
        </div>
    </div>
</section>

@* ---------- RSVP ---------- *@
<section class="section section-rsvp">
    <div class="container narrow center">
        <h2 class="section-title light">@C.RsvpHeading</h2>
        <p class="lead light">@C.RsvpText</p>
        <a class="btn btn-cream btn-lg" href="@SiteConfig.GoogleFormUrl" target="_blank" rel="noopener">
            @C.RsvpButton
        </a>
        <p class="deadline">@C.RsvpDeadline</p>
    </div>
</section>

@* ---------- KONTAKT ---------- *@
<section class="section section-contact">
    <div class="container narrow center">
        <h2 class="section-title">@C.ContactHeading</h2>
        <p class="lead">@C.ContactText</p>

        <ContactForm />

        <div class="contact-direct">
            <span class="contact-or">@C.ContactOr</span>
            <div class="contact-buttons">
                <a class="btn btn-outline" href="@SiteConfig.MessengerUrl" target="_blank" rel="noopener">@C.MessengerLabel</a>
                <a class="btn btn-outline" href="@SiteConfig.PhoneHref">@C.PhoneLabel: @SiteConfig.PhoneNumber</a>
                <a class="btn btn-outline" href="mailto:@SiteConfig.ContactEmail">@SiteConfig.ContactEmail</a>
            </div>
        </div>
    </div>
</section>

@* ---------- PÄTIČKA ---------- *@
<footer class="footer">
    <p class="footer-names">@C.CoupleNames</p>
    <p class="footer-sign">@C.FooterSignature</p>
    <p class="footer-date">26. 9. 2026 · Lysovický rybník</p>
    <a class="footer-menu-link" href="menu">@C.MenuNavLabel <span aria-hidden="true">→</span></a>
</footer>

@code {
    // Jemná botanická vetvička do rohov hero sekcie (štýl ladí s pozvánkou).
    private readonly MarkupString _branch = new(@"
        <g fill='none' stroke='currentColor' stroke-width='1.4' stroke-linecap='round'>
          <path d='M14 186 C72 150 112 108 156 34' />
        </g>
        <g fill='currentColor'>
          <ellipse cx='150' cy='44'  rx='14' ry='5'   transform='rotate(-35 150 44)' />
          <ellipse cx='132' cy='66'  rx='12' ry='4.5' transform='rotate(20 132 66)' />
          <ellipse cx='116' cy='86'  rx='14' ry='5'   transform='rotate(-35 116 86)' />
          <ellipse cx='98'  cy='108' rx='12' ry='4.5' transform='rotate(20 98 108)' />
          <ellipse cx='82'  cy='128' rx='14' ry='5'   transform='rotate(-35 82 128)' />
          <ellipse cx='64'  cy='150' rx='12' ry='4.5' transform='rotate(20 64 150)' />
          <ellipse cx='48'  cy='168' rx='13' ry='5'   transform='rotate(-35 48 168)' />
        </g>");

    // Malá ozdobná vetvička (delič) pod menami.
    private readonly MarkupString _sprig = new(@"
        <g stroke='currentColor' stroke-width='1.1'>
          <line x1='28' y1='11' x2='86' y2='11' />
          <line x1='114' y1='11' x2='172' y2='11' />
        </g>
        <g fill='currentColor'>
          <path d='M100 2 L105 11 L100 20 L95 11 Z' />
          <ellipse cx='88'  cy='11' rx='7' ry='2.6' transform='rotate(-22 88 11)' />
          <ellipse cx='112' cy='11' rx='7' ry='2.6' transform='rotate(22 112 11)' />
        </g>");
}
