@inherits LocalizedComponentBase

<div class="lang-switcher @(Inline ? "lang-switcher-inline" : null)" role="group" aria-label="Jazyk / Language">
    @foreach (var (code, label) in _langs)
    {
        var isActive = Loc.CurrentLanguage == code;
        <button type="button"
                class="lang-btn @(isActive ? "active" : null)"
                aria-pressed="@isActive"
                @onclick="() => Loc.SetLanguageAsync(code)">
            @label
        </button>
    }
</div>

@code {
    /// <summary>If true, renders without fixed positioning (for embedding in the nav bar).</summary>
    [Parameter] public bool Inline { get; set; }

    private readonly (Language Code, string Label)[] _langs =
    {
        (Language.Sk, "SK"),
        (Language.Cz, "CZ"),
        (Language.En, "EN"),
    };
}
